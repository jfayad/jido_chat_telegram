# Enable the live Telegram integration test module.
# Accepted truthy values: 1, true, TRUE, yes, on
RUN_LIVE_TELEGRAM_TESTS=false

# Telegram bot token (required when RUN_LIVE_TELEGRAM_TESTS=true)
# Example: 123456789:AA...<snip>
TELEGRAM_BOT_TOKEN=

# Chat id used for live integration tests (required when RUN_LIVE_TELEGRAM_TESTS=true)
# Example: 123456789 or -1001234567890
TELEGRAM_TEST_CHAT_ID=

# Optional: forum-enabled supergroup chat id used for live open_thread/createForumTopic coverage
# Example: -1001234567890
TELEGRAM_TEST_FORUM_CHAT_ID=

# Optional: forum topic/thread id for group topics
TELEGRAM_TEST_THREAD_ID=

# Optional: reaction emoji used by live reaction coverage
TELEGRAM_TEST_REACTION=👍

# Optional: callback query id for manual callback answer coverage
TELEGRAM_TEST_CALLBACK_QUERY_ID=

# Optional: override media references used by live media coverage
TELEGRAM_TEST_PHOTO_REF=https://httpbin.org/image/png
TELEGRAM_TEST_DOCUMENT_REF=https://www.w3.org/WAI/ER/tests/xhtml/testfiles/resources/pdf/dummy.pdf
